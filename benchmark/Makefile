####### Compile

out/obj/main.o: src/main.cpp inc/MainWindow.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/main.o src/main.cpp

out/obj/MainWindow.o: src/MainWindow.cpp inc/MainWindow.h \
		out/ui/ui_MainWindow.h \
		inc/RenderWidget.h \
		inc/Renderer.h \
		inc/Geom.h \
		inc/Camera.h \
		inc/Scene.h \
		inc/Gear.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/MainWindow.o src/MainWindow.cpp

out/obj/Renderer.o: src/Renderer.cpp inc/Renderer.h \
		inc/Geom.h \
		inc/Camera.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/Renderer.o src/Renderer.cpp

out/obj/RenderWidget.o: src/RenderWidget.cpp inc/RenderWidget.h \
		inc/Renderer.h \
		inc/Geom.h \
		inc/Camera.h \
		inc/Scene.h \
		inc/Gear.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/RenderWidget.o src/RenderWidget.cpp

out/obj/Scene.o: src/Scene.cpp inc/Scene.h \
		inc/Gear.h \
		inc/Geom.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/Scene.o src/Scene.cpp

out/obj/Camera.o: src/Camera.cpp inc/Camera.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/Camera.o src/Camera.cpp

out/obj/Gear.o: src/Gear.cpp inc/Gear.h \
		inc/Geom.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/Gear.o src/Gear.cpp

out/obj/moc_MainWindow.o: out/moc/moc_MainWindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/moc_MainWindow.o out/moc/moc_MainWindow.cpp

out/obj/moc_RenderWidget.o: out/moc/moc_RenderWidget.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o out/obj/moc_RenderWidget.o out/moc/moc_RenderWidget.cpp

